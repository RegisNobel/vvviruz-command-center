# Docker runtime env vars for vvviruz' command center
# Use the raw scrypt hash format here. Do not escape the $ separators.
AUTH_SECRET=replace-with-a-64-character-random-secret
ADMIN_USERNAME=owner
ADMIN_PASSWORD_HASH=scrypt$replace-salt$replace-derived-key
ADMIN_TOTP_ISSUER=vvviruz Command Center
ADMIN_SESSION_TTL_HOURS=12
ADMIN_PREAUTH_TTL_MINUTES=10

